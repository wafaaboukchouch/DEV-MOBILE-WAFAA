<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fond_calc"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@color/display_bg"
        android:gravity="end|center_vertical"
        android:padding="16dp"
        android:text="0"
        android:textColor="@color/texte_display"
        android:textSize="42sp" />

    <!-- Ligne 1: AC +/- % / -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="4dp">
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="AC" android:onClick="onClearClick"
            android:background="@color/btn_fonc" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="+/-" android:onClick="onChangeSign"
            android:background="@color/btn_fonc" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="%" android:onClick="onPercentageClick"
            android:background="@color/btn_fonc" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="/" android:onClick="onOperatorClick"
            android:background="@color/btn_operateur" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
    </LinearLayout>

    <!-- Ligne 2: 7 8 9 x -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="4dp">
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="7" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="8" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="9" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="x" android:onClick="onOperatorClick"
            android:background="@color/btn_operateur" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
    </LinearLayout>

    <!-- Ligne 3: 4 5 6 - -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="4dp">
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="4" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="5" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="6" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="-" android:onClick="onOperatorClick"
            android:background="@color/btn_operateur" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
    </LinearLayout>

    <!-- Ligne 4: 1 2 3 + -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="4dp">
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="1" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="2" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="3" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="+" android:onClick="onOperatorClick"
            android:background="@color/btn_operateur" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
    </LinearLayout>

    <!-- Ligne 5: 0 . = -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="4dp">
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="2" android:text="0" android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="." android:onClick="onNumberClick"
            android:background="@color/btn_chiffre" android:textColor="@color/texte_btn"
            android:layout_margin="2dp"/>
        <Button android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="=" android:onClick="onEqualsClick"
            android:background="@color/btn_egal" android:textColor="@color/texte_egal"
            android:layout_margin="2dp"/>
    </LinearLayout>

</LinearLayout>
